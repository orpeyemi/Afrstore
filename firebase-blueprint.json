{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury footwear product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "textures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "customizationOptions": { "type": "object" },
        "isLive": { "type": "boolean" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "status": { "type": "string" },
        "customInitials": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "total": { "type": "number" }
      },
      "required": ["userId", "items", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "orderLegacy": { "type": "array" },
        "savedDesigns": { "type": "array" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Luxury product collection."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase orders."
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    }
  }
}
